{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IPA Keyboard",
  "version": "0.1.0",
  "identifier": "com.minhphan.ipa-keyboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "IPA Keyboard",
        "width": 900,
        "height": 320,
        "minWidth": 500,
        "minHeight": 200,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": null,
      "hardenedRuntime": true,
      "minimumSystemVersion": "12.0",
      "frameworks": []
    },
    "category": "public.app-category.utilities",
    "resources": ["PrivacyInfo.xcprivacy", "icons/tray-icon-active.png", "icons/tray-icon-active@2x.png", "icons/tray-icon-inactive.png", "icons/tray-icon-inactive@2x.png"]
  }
}
